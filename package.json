{
  "name": "scenecast",
  "version": "0.6.0",
  "description": "The scene SDK for AI agents. Typed assets, canonical views, OTel emission, and scene diffing — one package.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./asset": "./src/asset.ts",
    "./view": "./src/view.ts",
    "./widgets": "./src/widgets.ts",
    "./types": "./src/types/index.ts",
    "./types/*": "./src/types/*.ts",
    "./vendors/*": "./src/vendors/*.ts",
    "./views/*": "./src/views/*.ts",
    "./render/*": "./src/render/*.ts",
    "./styles/widgets.css": "./src/styles/widgets.css",
    "./styles/*": "./src/styles/*",
    "./otel": "./src/otel.ts",
    "./diff": "./src/diff.ts"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.1"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "files": [
    "src",
    "schemas",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "bun test src/",
    "build:gallery": "bun gallery/build.ts",
    "verify:gallery": "bun gallery/verify-themes.ts"
  },
  "keywords": [
    "agent",
    "ai",
    "llm",
    "scene",
    "asset",
    "view",
    "schema",
    "json-schema",
    "automationbench",
    "rl",
    "verifiers",
    "scene-otel"
  ],
  "devDependencies": {
    "@a2ui/lit": "0.9.3",
    "@a2ui/web_core": "0.9.2",
    "@opentelemetry/context-async-hooks": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@types/bun": "latest",
    "playwright": "^1.59.1",
    "typescript": "^5.6.0"
  }
}